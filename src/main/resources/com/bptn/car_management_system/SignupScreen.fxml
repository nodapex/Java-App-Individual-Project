<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bptn.car_management_system.controllers.SignUpController">
   <children>
      <Label layoutX="225.0" layoutY="23.0" text="Registration Screen" textFill="#141313">
         <font>
            <Font name="Arial Black" size="18.0" />
         </font>
      </Label>
      <Button fx:id="btnExitSignupScreen" cancelButton="true" layoutX="221.0" layoutY="308.0" mnemonicParsing="false" onAction="#switchToLoginScreen" prefHeight="25.0" prefWidth="159.0" text="Exit" />
      <Label layoutX="65.0" layoutY="78.0" prefHeight="17.0" prefWidth="61.0" text="Username:" />
      <Label layoutX="67.0" layoutY="112.0" prefHeight="17.0" prefWidth="61.0" text="Firstname:" />
      <Label layoutX="69.0" layoutY="148.0" prefHeight="17.0" prefWidth="61.0" text="Lastname:" />
      <Label layoutX="91.0" layoutY="183.0" prefHeight="17.0" prefWidth="37.0" text="Email:" />
      <Label layoutX="72.0" layoutY="223.0" prefHeight="17.0" prefWidth="61.0" text="Password:" />
      <TextField fx:id="txtUsername" layoutX="138.0" layoutY="74.0" prefHeight="25.0" prefWidth="416.0" promptText="Enter your username">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </TextField>
      <TextField fx:id="txtFirstname" layoutX="138.0" layoutY="108.0" prefHeight="25.0" prefWidth="416.0" promptText="Enter your username">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </TextField>
      <TextField fx:id="txtLastname" layoutX="138.0" layoutY="144.0" prefHeight="25.0" prefWidth="416.0" promptText="Enter your username">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </TextField>
      <TextField fx:id="txtEmail" layoutX="138.0" layoutY="179.0" prefHeight="25.0" prefWidth="416.0" promptText="Enter your username">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </TextField>
      <PasswordField fx:id="txtPassword" layoutX="138.0" layoutY="219.0" prefHeight="25.0" prefWidth="416.0" promptText="Enter your password" />
      <TextField fx:id="txtPlateNumber" layoutX="138.0" layoutY="252.0" prefHeight="25.0" prefWidth="416.0" promptText="Enter your username">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </TextField>
      <Label layoutX="8.0" layoutY="255.0" prefHeight="17.0" prefWidth="127.0" text="Vehicle Plate Number:" />
      <Label fx:id="lblMessage" layoutX="130.0" layoutY="50.0" prefHeight="17.0" prefWidth="426.0" textFill="#d00c0c" />
      <Button fx:id="btnSave" defaultButton="true" layoutX="395.0" layoutY="308.0" mnemonicParsing="false" onAction="#registerUser" prefHeight="25.0" prefWidth="159.0" text="Save Data" />
   </children>
</AnchorPane>
